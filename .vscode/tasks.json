{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build and Run",
            "type": "shell",
            "command": "g++ main.cpp C:/OpenGL/Glad/src/glad.c -o Engine.exe -IC:/OpenGL/SDL3/SDL3-3.4.8/x86_64-w64-mingw32/include -IC:/OpenGL/Glad/include -LC:/OpenGL/SDL3/SDL3-3.4.8/x86_64-w64-mingw32/lib -lSDL3 -lopengl32 ; ./Engine.exe",

            "options": {
                "cwd": "${workspaceFolder}"
            },

            "group": {
                "kind": "build",
                "isDefault": true
            },

            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}