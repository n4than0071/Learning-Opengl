{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build SDL3",
            "type": "shell",
            "command": "g++",
            "args": [
                "main.cpp",
                "-o",
                "Engine.exe",
                "-IC:/SDL3/SDL3-3.4.8/x86_64-w64-mingw32/include",
                "-LC:/SDL3/SDL3-3.4.8/x86_64-w64-mingw32/lib",
                "-lSDL3"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}